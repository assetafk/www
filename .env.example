## App
# In docker-compose, DATABASE_URL should point to "db" hostname.
DATABASE_URL=postgresql+psycopg2://flashsale:flashsale@db:5432/flashsale
REDIS_URL=redis://redis:6379/0
RESERVATION_TTL_SECONDS=300
LOG_LEVEL=INFO

## Postgres (docker compose)
POSTGRES_DB=flashsale
POSTGRES_USER=flashsale
POSTGRES_PASSWORD=flashsale

## Optional test DB name (scripts/test.sh will create it)
TEST_DATABASE_NAME=flashsale_test
